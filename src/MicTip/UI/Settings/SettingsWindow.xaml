<Window x:Class="MicTip.UI.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MicTip.Models"
        Title="MicTip 设置" SizeToContent="WidthAndHeight" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8FAFC"
        FontFamily="Microsoft YaHei UI"
        FontSize="13"
        Icon="/UI/Icons/mic-on.ico"
        ShowInTaskbar="True">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="12,8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 快捷键 -->
        <GroupBox Header="快捷键" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>

                <TextBlock Text="切换静音" Style="{StaticResource Label}" Grid.Row="0"/>
                <TextBox x:Name="ToggleHotkeyBox" Grid.Row="0" Grid.Column="1" IsReadOnly="True"
                          PreviewKeyDown="OnHotkeyKeyDown" Margin="0,4,8,4" VerticalContentAlignment="Center"/>
                <Button Content="清除" Grid.Row="0" Grid.Column="2" Width="56" Margin="0,4"
                         Click="OnClearToggle" Tag="0"/>

                <TextBlock Text="说话(PTT)" Style="{StaticResource Label}" Grid.Row="1"/>
                <TextBox x:Name="PttHotkeyBox" Grid.Row="1" Grid.Column="1" IsReadOnly="True"
                          PreviewKeyDown="OnHotkeyKeyDown" Margin="0,4,8,4" VerticalContentAlignment="Center"/>
                <Button Content="清除" Grid.Row="1" Grid.Column="2" Width="56" Margin="0,4"
                         Click="OnClearPtt" Tag="1"/>
            </Grid>
        </GroupBox>

        <!-- 设备 -->
        <GroupBox Header="目标设备" Grid.Row="1">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <TextBlock Text="策略" Style="{StaticResource Label}" Grid.Row="0"/>
                <ComboBox x:Name="StrategyBox" Grid.Row="0" Grid.Column="1"
                          SelectionChanged="OnStrategyChanged" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="跟随默认设备" Tag="{x:Static models:DeviceStrategy.DefaultConsole}"/>
                    <ComboBoxItem Content="跟随默认通讯设备" Tag="{x:Static models:DeviceStrategy.DefaultComm}"/>
                    <ComboBoxItem Content="指定设备" Tag="{x:Static models:DeviceStrategy.Specific}"/>
                    <ComboBoxItem Content="静音全部设备" Tag="{x:Static models:DeviceStrategy.All}"/>
                </ComboBox>

                <TextBlock Text="指定设备" Style="{StaticResource Label}" Grid.Row="1"/>
                <ComboBox x:Name="DeviceBox" Grid.Row="1" Grid.Column="1" VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- 悬浮窗 -->
        <GroupBox Header="悬浮窗" Grid.Row="2">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>

                <TextBlock Text="选项" Style="{StaticResource Label}" Grid.Row="0"/>
                <CheckBox x:Name="OverlayEnabledBox" Content="启用悬浮窗" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>

                <TextBlock Text="位置对齐" Style="{StaticResource Label}" Grid.Row="1"/>
                <ComboBox x:Name="PositionBox" Grid.Row="1" Grid.Column="1" VerticalContentAlignment="Center"
                          SelectionChanged="OnPositionChanged">
                    <ComboBoxItem Content="右下角" Tag="{x:Static models:OverlayPosition.BottomRight}"/>
                    <ComboBoxItem Content="左下角" Tag="{x:Static models:OverlayPosition.BottomLeft}"/>
                    <ComboBoxItem Content="右上角" Tag="{x:Static models:OverlayPosition.TopRight}"/>
                    <ComboBoxItem Content="左上角" Tag="{x:Static models:OverlayPosition.TopLeft}"/>
                    <ComboBoxItem Content="自定义" Tag="{x:Static models:OverlayPosition.Custom}"/>
                </ComboBox>

                <TextBlock Text="自定义坐标" Style="{StaticResource Label}" Grid.Row="2"/>
                <Grid Grid.Row="2" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="X:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="OverlayXBox" Grid.Column="1" Margin="0,4,8,4" VerticalContentAlignment="Center" TextChanged="OnCoordinatesChanged"/>
                    <TextBlock Text="Y:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="OverlayYBox" Grid.Column="3" Margin="0,4,0,4" VerticalContentAlignment="Center" TextChanged="OnCoordinatesChanged"/>
                </Grid>

                <TextBlock Text="快捷调整" Style="{StaticResource Label}" Grid.Row="3"/>
                <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center">
                    <Button x:Name="CenterHorizontallyBtn" Content="水平居中" Width="88" Height="26" Margin="0,0,8,0" Click="OnCenterHorizontally"/>
                    <Button x:Name="CenterVerticallyBtn" Content="垂直居中" Width="88" Height="26" Click="OnCenterVertically"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 无声提醒 -->
        <GroupBox Header="无声提醒" Grid.Row="3">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="启用" Style="{StaticResource Label}" Grid.Row="0"/>
                <CheckBox x:Name="IdleAlertEnabledBox" Content="麦克风长时间无声音时弹窗提醒" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>

                <TextBlock Text="触发时长" Style="{StaticResource Label}" Grid.Row="1"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="无声音 " VerticalAlignment="Center"/>
                    <TextBox x:Name="IdleThresholdBox" Width="48" Margin="4,4,4,4" VerticalContentAlignment="Center" PreviewTextInput="OnNumericOnly"/>
                    <TextBlock Text=" 分钟后提醒 (仅电脑活跃时检测)" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,0,0"
                           Foreground="#6B7280" FontSize="11" TextWrapping="Wrap"
                           Text="提醒弹出时, 按切换静音的快捷键可快速关闭本次提醒 (不会切换静音); 仅在麦克风非静音时检测"/>
            </Grid>
        </GroupBox>

        <!-- 配置存储位置 -->
        <GroupBox Header="配置存储" Grid.Row="4">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <TextBlock Text="当前位置" Style="{StaticResource Label}" Grid.Row="0"/>
                <TextBlock x:Name="ConfigPathText" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Foreground="#4B5563"/>
                <Button Content="打开目录" Grid.Row="0" Grid.Column="2" Width="80" Height="26" Margin="8,0,0,0"
                        Click="OnOpenConfigFolder"/>

                <TextBlock Text="便携模式" Style="{StaticResource Label}" Grid.Row="1"/>
                <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"
                           Foreground="#6B7280" FontSize="11"
                           Text="若 exe 同目录下存在 settings.json 则自动启用便携模式, 配置随程序走"/>
                <Button x:Name="TogglePortableBtn" Grid.Row="1" Grid.Column="2" Width="80" Height="26" Margin="8,0,0,0"
                        Click="OnTogglePortable" ToolTip="在 exe 同目录创建/删除 settings.json 以切换便携模式"/>
            </Grid>
        </GroupBox>

        <!-- 底部按钮 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="5" Margin="12,12,12,4">
            <Button Content="确定" Width="88" Height="30" Margin="0,0,8,0" Click="OnOK"
                    IsDefault="True"/>
            <Button Content="取消" Width="88" Height="30" Click="OnCancel"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
