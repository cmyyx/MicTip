<Window x:Class="MicTip.UI.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MicTip Overlay"
        Height="104" Width="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        ShowActivated="False"
        Visibility="Hidden">

    <Border x:Name="RootBorder"
            CornerRadius="16"
            Padding="18,14"
            Margin="10"
            BorderThickness="1"
            BorderBrush="#33FFFFFF"
            MouseLeftButtonDown="OnDragStart">
        <Border.Background>
            <SolidColorBrush x:Name="RootBackground" Color="#E81F2937"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect x:Name="Shadow"
                              Color="Black" BlurRadius="20" ShadowDepth="2" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 状态图标 -->
            <Viewbox Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center">
                <TextBlock x:Name="IconText" Text="🎤"
                           FontFamily="Segoe UI Emoji"/>
            </Viewbox>

            <!-- 文本 + 音量条 -->
            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Text="已静音" FontSize="17" FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock x:Name="DeviceText" Text="" FontSize="11" Opacity="0.72"
                           Foreground="White" TextTrimming="CharacterEllipsis"
                           Margin="0,2,0,0"/>
                <ProgressBar x:Name="MeterBar" Height="5" Margin="0,8,0,0"
                             Minimum="0" Maximum="1" Value="0"
                             Foreground="#22C55E"
                             BorderThickness="0">
                    <ProgressBar.Background>
                        <SolidColorBrush Color="#33FFFFFF"/>
                    </ProgressBar.Background>
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid x:Name="PART_Track">
                                <Border CornerRadius="3"
                                        Background="{TemplateBinding Background}"/>
                                <Border x:Name="PART_Indicator" CornerRadius="3"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"/>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
            </StackPanel>
        </Grid>
    </Border>
</Window>
